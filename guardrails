#!/usr/bin/env bash
# guardrails — personal git-hook quality layer.
#
# Subcommands:
#   install [--force] [--skip <hook>]      install hooks into the current repo
#   uninstall                              remove guardrails-managed hooks
#   run <hook>                             execute the named hook (invoked by installed shims)
#   doctor                                 self-check + tool reachability + enrolled-repos audit
#   migrate [--apply]                      migrate from legacy ~/.git-hooks-personal/ install
#   --global-template                      configure git init.templateDir for auto-install on new clones
#   --version | -V                         print version
#
# Exit codes: 0 ok | 10 validation | 20 already-installed | 30 conflict | 40 dep missing | 1 unknown
set -euo pipefail
IFS=$'\n\t'

GUARDRAILS_VERSION="0.3.3"
GUARDRAILS_API_VERSION="guardrails.v0"

# Resolve install dir. When run from brew, GUARDRAILS_HOME points at pkgshare.
# When run from a local checkout (dev), it points at the repo root.
_resolve_self_dir() {
  local self
  self=$(realpath "$0" 2>/dev/null || echo "$0")
  dirname "$self"
}
GUARDRAILS_SELF_DIR=$(_resolve_self_dir)

# Where this guardrails install reads its templates from.
# Homebrew install: /opt/homebrew/share/guardrails/
# Local dev:        same dir as the binary
GUARDRAILS_TEMPLATES="${GUARDRAILS_TEMPLATES:-$GUARDRAILS_SELF_DIR}"
if [[ ! -f "$GUARDRAILS_TEMPLATES/lefthook.yml" ]]; then
  # brew share layout
  for candidate in "/opt/homebrew/share/guardrails" "/usr/local/share/guardrails" "$GUARDRAILS_SELF_DIR/../share/guardrails"; do
    if [[ -f "$candidate/lefthook.yml" ]]; then
      GUARDRAILS_TEMPLATES="$candidate"
      break
    fi
  done
fi

GUARDRAILS_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/guardrails"
GUARDRAILS_OPT_OUT="$GUARDRAILS_CONFIG_DIR/.opt-out"

# Marker line inserted into installed hooks so we can identify ours.
GUARDRAILS_HOOK_MARKER="# guardrails-managed: $GUARDRAILS_API_VERSION"

# Hooks we own.
GUARDRAILS_HOOKS=(pre-commit pre-push commit-msg)

# ---------- output helpers ----------
red()    { printf '\033[31m%b\033[0m' "$*"; }
yellow() { printf '\033[33m%b\033[0m' "$*"; }
green()  { printf '\033[32m%b\033[0m' "$*"; }
dim()    { printf '\033[2m%b\033[0m' "$*"; }
die()    { local code=$1; shift; printf '%s %s\n' "$(red ERROR:)" "$*" >&2; exit "$code"; }
warn()   { printf '%s %s\n' "$(yellow WARN:)" "$*" >&2; }
info()   { printf '%s\n' "$*" >&2; }

# ---------- repo introspection ----------
_repo_toplevel() {
  git rev-parse --show-toplevel 2>/dev/null
}

_repo_hooks_dir() {
  # The LITERAL .git/hooks/ for this repo, ignoring any core.hooksPath
  # override (we want to install per-repo, not into the global wt dir).
  local common
  common=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
  printf '%s/hooks' "$common"
}

_repo_local_hookspath() {
  git config --local --get core.hooksPath 2>/dev/null || true
}

_repo_global_hookspath() {
  git config --global --get core.hooksPath 2>/dev/null || true
}

_detect_hook_systems() {
  # Echo hook systems detected in the current repo, one per line.
  local repo="$1"
  [[ -d "$repo/.husky" ]] && echo "husky"
  [[ -f "$repo/lefthook.yml" || -f "$repo/lefthook.yaml" ]] && echo "lefthook"
  [[ -f "$repo/.pre-commit-config.yaml" ]] && echo "pre-commit-framework"
  [[ -d "$repo/.githooks" ]] && echo "githooks-custom"
  return 0
}

# Is the file at $1 owned by guardrails? (Marker present in file content.)
_is_guardrails_hook() {
  [[ -f "$1" ]] || return 1
  grep -Fq "$GUARDRAILS_HOOK_MARKER" "$1" 2>/dev/null
}

# ---------- generate hook shim ----------
_generate_shim() {
  local hook_name="$1"
  cat <<EOF
#!/usr/bin/env bash
$GUARDRAILS_HOOK_MARKER
# Generated by guardrails v$GUARDRAILS_VERSION on $(date -u +%Y-%m-%dT%H:%M:%SZ).
# DO NOT EDIT BY HAND. Run \`guardrails uninstall\` to remove.

exec guardrails run $hook_name "\$@"
EOF
}

# ---------- subcommands ----------
cmd_version() { echo "guardrails $GUARDRAILS_VERSION"; }

cmd_install() {
  local force=0 skip_hooks=()
  while (($#)); do
    case "$1" in
      --force) force=1; shift ;;
      --skip)  skip_hooks+=("$2"); shift 2 ;;
      -*)      die 10 "unknown flag: $1" ;;
      *)       die 10 "unexpected positional: $1" ;;
    esac
  done

  local repo
  repo=$(_repo_toplevel) || die 10 "not a git repo (run from inside one)"

  # Conflict detection.
  local local_hooks_path
  local_hooks_path=$(_repo_local_hookspath)
  if [[ -n "$local_hooks_path" ]] && (( force == 0 )); then
    # If the local hooksPath equals the global wt path, treat as harmless (wt-managed).
    local global_hooks_path
    global_hooks_path=$(_repo_global_hookspath)
    if [[ "$local_hooks_path" != "$global_hooks_path" ]]; then
      die 30 "this repo has a local core.hooksPath = $local_hooks_path

guardrails cannot safely install into .git/hooks/ because that local
override redirects hooks elsewhere. Options:

  1. Wire guardrails into the existing hook system. Add this one line
     near the top of $local_hooks_path/<hook> for each hook you want:

         [ -x \"\$(command -v guardrails)\" ] && guardrails run <hook>

  2. Override (NOT recommended unless you understand the consequences):
         guardrails install --force"
    fi
  fi

  local hook_systems
  hook_systems=$(_detect_hook_systems "$repo")
  if [[ -n "$hook_systems" ]] && (( force == 0 )); then
    warn "detected existing hook system(s) in this repo:"
    while IFS= read -r sys; do printf '       - %s\n' "$sys" >&2; done <<< "$hook_systems"
    warn "guardrails will install per-repo hooks alongside, but you may want to compose explicitly."
    warn "for example, in .husky/pre-commit add:"
    info "         [ -x \"\$(command -v guardrails)\" ] && guardrails run pre-commit"
  fi

  local hooks_dir
  hooks_dir=$(_repo_hooks_dir)
  [[ -n "$hooks_dir" ]] || die 10 "could not resolve hooks dir for $repo"
  mkdir -p "$hooks_dir"

  local installed=0 skipped=0 conflicted=0
  for hook in "${GUARDRAILS_HOOKS[@]}"; do
    # Honor --skip
    local skip=0
    for s in "${skip_hooks[@]:-}"; do [[ "$s" == "$hook" ]] && skip=1; done
    if (( skip == 1 )); then
      skipped=$((skipped + 1))
      continue
    fi

    local target="$hooks_dir/$hook"
    if [[ -e "$target" ]]; then
      if _is_guardrails_hook "$target"; then
        # Re-install: re-generate to pick up latest version.

        rm -f "$target"
        _generate_shim "$hook" > "$target"
        chmod +x "$target"
        installed=$((installed + 1))
        continue
      fi
      if (( force == 0 )); then
        warn "$hook already exists and is not managed by guardrails: $target"
        conflicted=$((conflicted + 1))
        continue
      fi
    fi
    # Write via rm-then-create to never follow a symlink target.
    rm -f "$target"
    _generate_shim "$hook" > "$target"
    chmod +x "$target"
    installed=$((installed + 1))
  done

  # If a global core.hooksPath shadows our install, set a local override so
  # git actually uses the hooks we just wrote. This is the "wt + guardrails
  # can't both win in the same repo" tradeoff: when you `guardrails install`
  # in a repo, that repo's hooks become guardrails-managed.
  if [[ -n "$(_repo_global_hookspath)" ]] && [[ -z "$(_repo_local_hookspath)" ]] && (( installed > 0 )); then
    git config --local core.hooksPath "$hooks_dir"
    info "→ set local core.hooksPath = $hooks_dir (overrides global)"
  fi

  green "installed "
  printf '%d/%d hooks in %s\n' "$installed" "${#GUARDRAILS_HOOKS[@]}" "$repo"
  (( skipped > 0 ))    && yellow "skipped: $skipped\n"
  (( conflicted > 0 )) && yellow "conflicts: $conflicted (use --force to override)\n"
  return 0
}

cmd_uninstall() {
  local repo
  repo=$(_repo_toplevel) || die 10 "not a git repo"
  local hooks_dir
  hooks_dir=$(_repo_hooks_dir) || die 10 "could not resolve hooks dir"

  local removed=0 not_ours=0
  for hook in "${GUARDRAILS_HOOKS[@]}"; do
    local target="$hooks_dir/$hook"
    [[ -e "$target" ]] || continue
    if _is_guardrails_hook "$target"; then
      rm -f "$target"
      removed=$((removed + 1))
    else
      not_ours=$((not_ours + 1))
    fi
  done

  # If the local core.hooksPath we set during install now points at an empty
  # set of our hooks, restore the global default by unsetting it.
  local local_hp; local_hp=$(_repo_local_hookspath)
  if [[ "$local_hp" == "$hooks_dir" ]]; then
    # Are there any non-guardrails hooks left to justify keeping the override?
    local any_other=0
    for hook in "${GUARDRAILS_HOOKS[@]}"; do
      [[ -f "$hooks_dir/$hook" ]] && any_other=1
    done
    if (( any_other == 0 )); then
      git config --local --unset core.hooksPath
      info "→ unset local core.hooksPath (restored global default)"
    fi
  fi

  green "uninstalled "
  printf '%d guardrails hooks from %s\n' "$removed" "$repo"
  (( not_ours > 0 )) && warn "left $not_ours non-guardrails hooks intact"
  return 0
}

cmd_run() {
  local hook="${1:-}"
  [[ -n "$hook" ]] || die 10 "usage: guardrails run <hook>"
  shift

  # Global bypass.
  [[ "${SKIP_PERSONAL_HOOKS:-0}" == "1" ]] && exit 0

  # User-owned per-repo opt-out.
  local repo
  repo=$(_repo_toplevel || true)
  if [[ -n "$repo" ]] && [[ -f "$GUARDRAILS_OPT_OUT" ]]; then
    if grep -Fxq "$repo" "$GUARDRAILS_OPT_OUT"; then
      exit 0
    fi
  fi

  # Defer to lefthook with our shipped config.
  local config="$GUARDRAILS_TEMPLATES/lefthook.yml"
  [[ -f "$config" ]] || die 40 "guardrails lefthook.yml not found at $config"

  # XDG init.sh (PATH extension before sanitization, if user wants it).
  local user_init="${XDG_CONFIG_HOME:-$HOME/.config}/guardrails/init.sh"
  [[ -r "$user_init" ]] && . "$user_init"

  # PATH sanitization (defense against hijack).
  export PATH="${GUARDRAILS_PATH:-/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:$HOME/.local/share/bun/bin:$HOME/.local/bin}"

  # Make GUARDRAILS_HOME visible to lefthook config (used for ${GUARDRAILS_HOME} expansions).
  export GUARDRAILS_HOME="$GUARDRAILS_TEMPLATES"

  case "$hook" in
    commit-msg)
      export LEFTHOOK_COMMIT_MSG_FILE="${1:-}"
      exec env LEFTHOOK_CONFIG="$config" lefthook run commit-msg --no-tty --no-auto-install -- "$@"
      ;;
    pre-push)
      # pre-push receives ref data on stdin. Run branch-guard directly (lefthook
      # consumes pre-push stdin for its templates), then exec lefthook with same.
      local tmp
      tmp=$(mktemp -t guardrails-prepush.XXXXXX)
      trap 'rm -f "$tmp"' EXIT
      cat > "$tmp"
      if [[ -z "${SKIP_BRANCH_GUARD:-}" ]] && ! "$GUARDRAILS_TEMPLATES/checks/branch-guard.sh" < "$tmp"; then
        exit 1
      fi
      env LEFTHOOK_CONFIG="$config" lefthook run pre-push --no-tty --no-auto-install < "$tmp"
      exit $?
      ;;
    *)
      exec env LEFTHOOK_CONFIG="$config" lefthook run "$hook" --no-tty --no-auto-install
      ;;
  esac
}

cmd_doctor() {
  local all=0 root="${HOME}/Documents/GitHub"
  while (($#)); do
    case "$1" in
      --all) all=1; shift ;;
      --root) root="$2"; shift 2 ;;
      -*) die 10 "unknown flag: $1" ;;
      *) die 10 "unexpected positional: $1" ;;
    esac
  done

  if (( all == 1 )); then
    cmd_doctor_all "$root"
    return $?
  fi
  local fail=0
  printf '%-40s' "guardrails version"; green "$GUARDRAILS_VERSION\n"
  printf '%-40s' "templates dir"
  if [[ -f "$GUARDRAILS_TEMPLATES/lefthook.yml" ]]; then green "$GUARDRAILS_TEMPLATES\n"
  else red "MISSING: $GUARDRAILS_TEMPLATES/lefthook.yml\n"; fail=1; fi

  for tool in lefthook gitleaks actionlint git bash bun commitlint; do
    printf '%-40s' "$tool reachable"
    if command -v "$tool" >/dev/null 2>&1; then
      green "$(command -v "$tool")\n"
    else
      yellow "NOT FOUND (some hooks may skip)\n"
    fi
  done

  printf '%-40s' "config dir"
  if [[ -d "$GUARDRAILS_CONFIG_DIR" ]]; then green "$GUARDRAILS_CONFIG_DIR\n"
  else dim "(absent — no opt-outs configured)\n"; fi

  # If we're inside a repo, also report install state for THIS repo.
  local repo
  repo=$(_repo_toplevel 2>/dev/null || true)
  if [[ -n "$repo" ]]; then
    printf '\n%s\n' "$(dim "─── current repo: $repo ───")"
    local hooks_dir; hooks_dir=$(_repo_hooks_dir)
    for hook in "${GUARDRAILS_HOOKS[@]}"; do
      printf '%-40s' "$hook"
      local target="$hooks_dir/$hook"
      if [[ -f "$target" ]]; then
        if _is_guardrails_hook "$target"; then green "installed (guardrails)\n"
        else yellow "present (not ours)\n"; fi
      else
        dim "not installed\n"
      fi
    done
    local lh; lh=$(_repo_local_hookspath)
    if [[ -n "$lh" ]]; then
      printf '%-40s' "local core.hooksPath"; yellow "$lh\n"
    fi
  fi

  return $fail
}

cmd_doctor_all() {
  local root="$1"
  [[ -d "$root" ]] || die 10 "scan root does not exist: $root"

  local installed=0 not_installed=0 bypass=0 opt_out=0 total=0
  local repos_installed=() repos_not_installed=() repos_bypass=() repos_optout=()

  # Walk the root looking for .git/ (or .git file for worktrees).
  while IFS= read -r repo; do
    [[ -z "$repo" ]] && continue
    total=$((total + 1))
    local cat
    cat=$(_audit_repo "$repo")
    case "$cat" in
      installed)
        repos_installed+=("$repo")
        installed=$((installed + 1))
        ;;
      not-installed)
        repos_not_installed+=("$repo")
        not_installed=$((not_installed + 1))
        ;;
      bypass)
        repos_bypass+=("$repo")
        bypass=$((bypass + 1))
        ;;
      opt-out)
        repos_optout+=("$repo")
        opt_out=$((opt_out + 1))
        ;;
    esac
  done < <(_find_git_repos "$root")

  printf 'guardrails doctor --all — scan root: %s\n' "$root"
  printf '  %d repos | ' "$total"
  green "$installed installed"; printf ' | '
  dim "$not_installed not-installed"; printf ' | '
  yellow "$bypass bypass"; printf ' | '
  dim "$opt_out opt-out"; printf '\n\n'

  if (( installed > 0 )); then
    green "installed — guardrails-managed hooks present:\n"
    for r in "${repos_installed[@]}"; do
      printf '  ✓ %s\n' "${r#$root/}"
    done
    printf '\n'
  fi

  if (( not_installed > 0 )); then
    dim "not-installed — run \`cd <repo> && guardrails install\` to enroll:\n"
    for r in "${repos_not_installed[@]}"; do
      printf '  · %s\n' "${r#$root/}"
    done
    printf '\n'
  fi

  if (( bypass > 0 )); then
    yellow "bypass — local core.hooksPath set to a non-guardrails path:\n"
    for r in "${repos_bypass[@]}"; do
      local hp; hp=$(git -C "$r" config --local --get core.hooksPath 2>/dev/null)
      printf '  ✗ %s   (hooksPath: %s)\n' "${r#$root/}" "$hp"
    done
    printf '  fix: in each, add this near the top of the existing hook script:\n'
    dim "    [ -x \"\$(command -v guardrails)\" ] && guardrails run <hook> \"\$@\" || true\n"
    printf '\n'
  fi

  if (( opt_out > 0 )); then
    dim "opt-out — explicitly skipped:\n"
    for r in "${repos_optout[@]}"; do
      printf '  — %s\n' "${r#$root/}"
    done
  fi
}

_find_git_repos() {
  local root="$1"
  # Find dirs that contain .git (either as dir or file for worktrees).
  # Stop descending into a repo once found.
  find "$root" -type d -maxdepth 5 \( -name node_modules -o -name .venv -o -name venv -o -name .worktrees \) -prune -o \
    \( -name .git -o -type f -name .git \) -print 2>/dev/null \
    | xargs -I {} dirname {} | sort -u
}

_audit_repo() {
  local repo="$1" canonical
  # Canonicalize for opt-out comparison (macOS /var → /private/var).
  canonical=$(cd "$repo" 2>/dev/null && pwd -P) || { echo "not-installed"; return; }

  if [[ -f "$GUARDRAILS_OPT_OUT" ]] && grep -Fxq "$canonical" "$GUARDRAILS_OPT_OUT"; then
    echo "opt-out"; return
  fi

  local hooks_dir
  hooks_dir=$(git -C "$repo" rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || { echo "not-installed"; return; }
  hooks_dir="$hooks_dir/hooks"

  # Check for guardrails marker in any of our hooks.
  local hook
  for hook in "${GUARDRAILS_HOOKS[@]}"; do
    if [[ -f "$hooks_dir/$hook" ]] && grep -Fq "$GUARDRAILS_HOOK_MARKER" "$hooks_dir/$hook" 2>/dev/null; then
      echo "installed"; return
    fi
  done

  # Local hooksPath set + not ours = bypass.
  local hp; hp=$(git -C "$repo" config --local --get core.hooksPath 2>/dev/null)
  if [[ -n "$hp" ]]; then
    echo "bypass"; return
  fi

  echo "not-installed"
}

cmd_global_template() {
  local template_dir="${XDG_DATA_HOME:-$HOME/.local/share}/guardrails/git-template"
  local hooks_dir="$template_dir/hooks"
  mkdir -p "$hooks_dir"
  for hook in "${GUARDRAILS_HOOKS[@]}"; do
    _generate_shim "$hook" > "$hooks_dir/$hook"
    chmod +x "$hooks_dir/$hook"
  done
  git config --global init.templateDir "$template_dir"
  green "global template installed "
  printf '%s\n' "$template_dir"
  info "→ new \`git init\` / \`git clone\` will auto-install guardrails hooks"
  info "→ undo: git config --global --unset init.templateDir"
}

cmd_migrate() {
  local apply=0
  while (($#)); do
    case "$1" in
      --apply) apply=1; shift ;;
      *) die 10 "unknown flag: $1" ;;
    esac
  done

  local legacy="$HOME/.git-hooks-personal"
  if [[ ! -d "$legacy" ]]; then
    green "no legacy install found "
    printf 'nothing to migrate\n'
    return 0
  fi

  info "→ legacy install detected at $legacy"
  info ""

  # Find repos enrolled via global core.hooksPath = $legacy
  local global_hp; global_hp=$(_repo_global_hookspath)
  if [[ "$global_hp" == "$legacy" ]]; then
    info "→ global core.hooksPath currently points at $legacy"
    info "  this will be unset (binary install puts guardrails on PATH)"
  fi

  # Find opt-out paths to preserve
  local legacy_optout="$legacy/.opt-out"
  if [[ -f "$legacy_optout" ]]; then
    info "→ legacy .opt-out found:"
    sed 's/^/     /' "$legacy_optout"
  fi

  if (( apply == 0 )); then
    info ""
    yellow "DRY RUN — re-run with --apply to perform the migration.\n"
    info "What would happen:"
    info "  1. Unset global core.hooksPath (if it points at $legacy)"
    info "  2. Copy $legacy/.opt-out to $GUARDRAILS_OPT_OUT (if present)"
    info "  3. Print a list of repos to run \`guardrails install\` in"
    info "  4. NOT delete $legacy (you do that manually after verifying)"
    return 0
  fi

  # Apply.
  if [[ "$global_hp" == "$legacy" ]]; then
    git config --global --unset core.hooksPath
    green "✓ unset global core.hooksPath\n"
  fi

  if [[ -f "$legacy_optout" ]]; then
    mkdir -p "$GUARDRAILS_CONFIG_DIR"
    cp "$legacy_optout" "$GUARDRAILS_OPT_OUT"
    green "✓ migrated opt-out file to $GUARDRAILS_OPT_OUT\n"
  fi

  info ""
  yellow "next: install guardrails per-repo in any repo you want covered.\n"
  info "for each repo:"
  info "  cd <repo> && guardrails install"
  info ""
  info "when you've verified the new install works:"
  info "  rm -rf $legacy"
}

# ---------- dispatch ----------
main() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    install)        cmd_install "$@" ;;
    uninstall)      cmd_uninstall "$@" ;;
    run)            cmd_run "$@" ;;
    doctor)         cmd_doctor "$@" ;;
    migrate)        cmd_migrate "$@" ;;
    --global-template) cmd_global_template "$@" ;;
    --version|-V)   cmd_version ;;
    -h|--help|help|"") cmd_help ;;
    *)              die 10 "unknown subcommand: $sub (try 'guardrails --help')" ;;
  esac
}

cmd_help() {
  cat <<EOF
guardrails $GUARDRAILS_VERSION — personal git-hook quality layer

usage:
  guardrails install [--force] [--skip <hook>]
                                     install hooks into the current repo (per-repo,
                                     ownership-marker based, conflict-aware)
  guardrails uninstall               remove only guardrails-managed hooks
  guardrails run <hook>              execute the named hook (invoked by installed shims)
  guardrails doctor                  audit current repo + tool reachability
  guardrails migrate [--apply]       migrate from legacy ~/.git-hooks-personal/ install
  guardrails --global-template       configure git init.templateDir for auto-install on new clones

  guardrails --version | -V
  guardrails --help

config:
  ${XDG_CONFIG_HOME:-$HOME/.config}/guardrails/         user config dir (opt-out, init.sh)
  $GUARDRAILS_TEMPLATES/lefthook.yml   source of truth for what runs

bypass:
  SKIP_PERSONAL_HOOKS=1                skip all guardrails checks
  SKIP_GITLEAKS=1 (etc.)               per-check skip
  ALLOW_PROTECTED_PUSH=1               one-time protected-branch override
  git commit --no-verify               nuclear (skips guardrails + repo hooks)
EOF
}

main "$@"
