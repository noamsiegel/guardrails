#!/usr/bin/env bash
# ai-git-guardrails — personal git-hook quality layer.
#
# Subcommands:
#   install [--force] [--skip <hook>]      install hooks into the current repo
#   uninstall                              remove ai-git-guardrails-managed hooks
#   run <hook>                             execute the named hook (invoked by installed shims)
#   doctor                                 self-check + tool reachability + enrolled-repos audit
#   migrate [--apply]                      migrate from legacy global-hooksPath install
#   --global-template                      configure git init.templateDir for auto-install on new clones
#   --version | -V                         print version
#
# Exit codes: 0 ok | 10 validation | 20 already-installed | 30 conflict | 40 dep missing | 1 unknown
set -euo pipefail
IFS=$'\n\t'

AI_GIT_GUARDRAILS_VERSION="0.8.0"
AI_GIT_GUARDRAILS_API_VERSION="ai-git-guardrails.v0"
LEGACY_GUARDRAILS_API_VERSION="guardrails.v0"

# Resolve install dir. When run from brew, AI_GIT_GUARDRAILS_HOME points at pkgshare.
# When run from a local checkout (dev), it points at the repo root.
_resolve_self_dir() {
  local self
  self=$(realpath "$0" 2>/dev/null || echo "$0")
  dirname "$self"
}
AI_GIT_GUARDRAILS_SELF_DIR=$(_resolve_self_dir)

# Where this ai-git-guardrails install reads its templates from.
# Homebrew install: /opt/homebrew/share/ai-git-guardrails/
# Local dev:        same dir as the binary
AI_GIT_GUARDRAILS_TEMPLATES="${AI_GIT_GUARDRAILS_TEMPLATES:-${GUARDRAILS_TEMPLATES:-$AI_GIT_GUARDRAILS_SELF_DIR}}"
if [[ ! -f "$AI_GIT_GUARDRAILS_TEMPLATES/lefthook.yml" ]]; then
  # brew share layout
  for candidate in "/opt/homebrew/share/ai-git-guardrails" "/usr/local/share/ai-git-guardrails" "$AI_GIT_GUARDRAILS_SELF_DIR/../share/ai-git-guardrails" "/opt/homebrew/share/guardrails" "/usr/local/share/guardrails" "$AI_GIT_GUARDRAILS_SELF_DIR/../share/guardrails"; do
    if [[ -f "$candidate/lefthook.yml" ]]; then
      AI_GIT_GUARDRAILS_TEMPLATES="$candidate"
      break
    fi
  done
fi
# Shell-readable universal checks registry.
if [[ ! -f "$AI_GIT_GUARDRAILS_TEMPLATES/checks/registry.sh" ]]; then
  printf '%s\n' "ERROR: ai-git-guardrails registry not found at $AI_GIT_GUARDRAILS_TEMPLATES/checks/registry.sh" >&2
  exit 40
fi
# shellcheck source=checks/registry.sh
. "$AI_GIT_GUARDRAILS_TEMPLATES/checks/registry.sh"


AI_GIT_GUARDRAILS_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/ai-git-guardrails"
LEGACY_GUARDRAILS_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/guardrails"
if [[ ! -d "$AI_GIT_GUARDRAILS_CONFIG_DIR" && -d "$LEGACY_GUARDRAILS_CONFIG_DIR" ]]; then
  if [[ "${1:-}" != "--version" && "${1:-}" != "-V" ]]; then
    printf '%s\n' "WARN: using legacy config dir $LEGACY_GUARDRAILS_CONFIG_DIR; move it to $AI_GIT_GUARDRAILS_CONFIG_DIR" >&2
  fi
  AI_GIT_GUARDRAILS_CONFIG_DIR="$LEGACY_GUARDRAILS_CONFIG_DIR"
fi
AI_GIT_GUARDRAILS_OPT_OUT="$AI_GIT_GUARDRAILS_CONFIG_DIR/.opt-out"

# Marker line inserted into installed hooks so we can identify ours.
AI_GIT_GUARDRAILS_HOOK_MARKER="# ai-git-guardrails-managed: $AI_GIT_GUARDRAILS_API_VERSION"
LEGACY_GUARDRAILS_HOOK_MARKER="# guardrails-managed: $LEGACY_GUARDRAILS_API_VERSION"

# Hooks we own.
AI_GIT_GUARDRAILS_HOOKS=(pre-commit pre-push commit-msg)

# ---------- output helpers ----------
red()    { printf '\033[31m%b\033[0m' "$*"; }
yellow() { printf '\033[33m%b\033[0m' "$*"; }
green()  { printf '\033[32m%b\033[0m' "$*"; }
dim()    { printf '\033[2m%b\033[0m' "$*"; }
die()    { local code=$1; shift; printf '%s %s\n' "$(red ERROR:)" "$*" >&2; exit "$code"; }
warn()   { printf '%s %s\n' "$(yellow WARN:)" "$*" >&2; }
info()   { printf '%s\n' "$*" >&2; }

# ---------- repo introspection ----------
_repo_toplevel() {
  git rev-parse --show-toplevel 2>/dev/null
}

_repo_hooks_dir() {
  # The LITERAL .git/hooks/ for this repo, ignoring any core.hooksPath
  # override (we want to install per-repo, not into the global wt dir).
  local common
  common=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
  printf '%s/hooks' "$common"
}

_repo_local_hookspath() {
  git config --local --get core.hooksPath 2>/dev/null || true
}

_repo_global_hookspath() {
  git config --global --get core.hooksPath 2>/dev/null || true
}

_detect_hook_systems() {
  # Echo hook systems detected in the current repo, one per line.
  local repo="$1"
  [[ -d "$repo/.husky" ]] && echo "husky"
  [[ -f "$repo/lefthook.yml" || -f "$repo/lefthook.yaml" ]] && echo "lefthook"
  [[ -f "$repo/.pre-commit-config.yaml" ]] && echo "pre-commit-framework"
  [[ -d "$repo/.githooks" ]] && echo "githooks-custom"
  return 0
}

_resolve_hookspath() {
  local repo="$1" hookspath="$2"
  [[ -n "$hookspath" ]] || return 1
  case "$hookspath" in
    /*) printf '%s' "$hookspath" ;;
    *)  printf '%s/%s' "$repo" "$hookspath" ;;
  esac
}

_repo_is_opted_out() {
  local repo="$1" canonical
  [[ -n "$repo" && -f "$AI_GIT_GUARDRAILS_OPT_OUT" ]] || return 1
  canonical=$(cd "$repo" 2>/dev/null && pwd -P) || return 1
  grep -Fxq "$canonical" "$AI_GIT_GUARDRAILS_OPT_OUT" 2>/dev/null
}

# Classify one hook file. Echoes: absent | ours | non-ours | shadowed | opt-out.
_classify_hook() {
  local hooks_dir="$1" hook="$2"
  local repo local_hp global_hp active_hp target

  repo=$(_repo_toplevel 2>/dev/null || true)
  if [[ -n "$repo" ]] && _repo_is_opted_out "$repo"; then
    echo "opt-out"
    return 0
  fi

  if [[ -n "$repo" ]]; then
    local_hp=$(_repo_local_hookspath)
    global_hp=$(_repo_global_hookspath)
    if [[ -n "$local_hp" ]]; then
      active_hp=$(_resolve_hookspath "$repo" "$local_hp")
    elif [[ -n "$global_hp" ]]; then
      active_hp=$(_resolve_hookspath "$repo" "$global_hp")
    else
      active_hp="$hooks_dir"
    fi
    if [[ -n "$active_hp" && "$active_hp" != "$hooks_dir" ]]; then
      echo "shadowed"
      return 0
    fi
  fi

  target="$hooks_dir/$hook"
  if [[ ! -e "$target" ]]; then
    echo "absent"
  elif grep -Fq "$AI_GIT_GUARDRAILS_HOOK_MARKER" "$target" 2>/dev/null; then
    echo "ours"
  # Backward-compat: existing installs used this ownership marker before the rename.
  elif grep -Fq "$LEGACY_GUARDRAILS_HOOK_MARKER" "$target" 2>/dev/null; then
    echo "ours"
  else
    echo "non-ours"
  fi
}

# Classify all owned hooks for a repo. TSV: hook owner path hooksPath_local hooksPath_global opt_out
_classify_repo_hooks() {
  local repo="$1" hooks_dir local_hp global_hp opt_out hook owner path local_hp_field global_hp_field
  hooks_dir=$(git -C "$repo" rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
  hooks_dir="$hooks_dir/hooks"
  local_hp=$(git -C "$repo" config --local --get core.hooksPath 2>/dev/null || true)
  global_hp=$(git -C "$repo" config --global --get core.hooksPath 2>/dev/null || true)
  opt_out=0
  _repo_is_opted_out "$repo" && opt_out=1
  local_hp_field="${local_hp:-.}"
  global_hp_field="${global_hp:-.}"

  for hook in "${AI_GIT_GUARDRAILS_HOOKS[@]}"; do
    path="$hooks_dir/$hook"
    owner=$(cd "$repo" && _classify_hook "$hooks_dir" "$hook")
    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$hook" "$owner" "$path" "$local_hp_field" "$global_hp_field" "$opt_out"
  done
}

# Is the file at $1 owned by ai-git-guardrails?
_is_ai_git_guardrails_hook() {
  local hook_file="$1" hooks_dir hook
  [[ -f "$hook_file" ]] || return 1
  hooks_dir=$(dirname "$hook_file")
  hook=$(basename "$hook_file")
  [[ "$(_classify_hook "$hooks_dir" "$hook")" == "ours" ]]
}
have() {
  command -v "$1" >/dev/null 2>&1
}

_registry_skip_envs_for_hook() {
  local hook="$1" entry entry_hook _command skip_env _required_tools _rationale
  for entry in "${AI_GIT_GUARDRAILS_CHECKS[@]}"; do
    IFS='|' read -r entry_hook _command skip_env _required_tools _rationale <<< "$entry"
    [[ "$entry_hook" == "$hook" ]] || continue
    printf '%s=1 ' "$skip_env"
  done
}


# ---------- generate hook shim ----------

# Print the canonical compose snippet for <hook> in <mode>.
#
# Modes:
#   embedded    — for embedding inside an existing hook script (pre-commit
#                 framework, lefthook, manual script). Preserves "$@",
#                 preserves stdin (required for pre-push ref lines),
#                 propagates ai-git-guardrails' exit code, and does not exec so
#                 downstream hook logic can continue when ai-git-guardrails passes.
#   standalone  — for writing as a complete hook file. Uses exec, includes the
#                 ownership marker, and matches installed/global-template hooks.
#   bypass-help — for diagnostic messages: a single shell line that opts out of
#                 ai-git-guardrails for one hook invocation while preserving args/stdin.
#
# Args/stdin/exit:
#   - "$@" is forwarded in every mode (commit-msg needs the message path).
#   - stdin is untouched; embedded pre-push keeps Git's ref update stream.
#   - embedded exits with ai-git-guardrails' non-zero status and continues on zero.
_compose_snippet() {
  local hook="$1" mode="$2"

  case "$mode" in
    embedded)
      cat <<EOF
# ai-git-guardrails compose: $hook
# Preserves "\$@" and stdin; exits non-zero if ai-git-guardrails blocks.
if command -v ai-git-guardrails >/dev/null 2>&1; then
  ai-git-guardrails run $hook "\$@" || exit \$?
fi
EOF
      ;;
    standalone)
      cat <<EOF
#!/usr/bin/env bash
$AI_GIT_GUARDRAILS_HOOK_MARKER
# Generated by ai-git-guardrails v$AI_GIT_GUARDRAILS_VERSION on $(date -u +%Y-%m-%dT%H:%M:%SZ).
# DO NOT EDIT BY HAND. Run \`ai-git-guardrails uninstall\` to remove.

exec ai-git-guardrails run $hook "\$@"
EOF
      ;;
    bypass-help)
      printf '%sai-git-guardrails run %s "$@" || true\n' "$(_registry_skip_envs_for_hook "$hook")" "$hook"
      ;;
    *)
      return 1
      ;;
  esac
}

_generate_shim() {
  local hook_name="$1"
  _compose_snippet "$hook_name" standalone
}

# ---------- subcommands ----------
cmd_version() { echo "ai-git-guardrails $AI_GIT_GUARDRAILS_VERSION"; }

cmd_install() {
  local force=0 skip_hooks=()
  while (($#)); do
    case "$1" in
      --force) force=1; shift ;;
      --skip)  skip_hooks+=("$2"); shift 2 ;;
      -*)      die 10 "unknown flag: $1" ;;
      *)       die 10 "unexpected positional: $1" ;;
    esac
  done

  local repo
  repo=$(_repo_toplevel) || die 10 "not a git repo (run from inside one)"

  # Conflict detection.
  local local_hooks_path hooks_dir
  local_hooks_path=$(_repo_local_hookspath)
  hooks_dir=$(_repo_hooks_dir)
  [[ -n "$hooks_dir" ]] || die 10 "could not resolve hooks dir for $repo"
  if [[ -n "$local_hooks_path" ]] && (( force == 0 )); then
    # If the local hooksPath already points at this repo's .git/hooks or equals
    # the global wt path, treat as harmless.
    local global_hooks_path resolved_local_hooks_path
    global_hooks_path=$(_repo_global_hookspath)
    resolved_local_hooks_path=$(_resolve_hookspath "$repo" "$local_hooks_path")
    if [[ "$resolved_local_hooks_path" != "$hooks_dir" && "$local_hooks_path" != "$global_hooks_path" ]]; then
      {
        printf '%s\n\n' "this repo has a local core.hooksPath = $local_hooks_path"
        printf '%s\n' "ai-git-guardrails cannot safely install into .git/hooks/ because that local"
        printf '%s\n' "override redirects hooks elsewhere. Options:"
        printf '\n'
        printf '%s\n' "  1. Wire ai-git-guardrails into the existing hook system. Add this snippet"
        printf '%s\n\n' "     near the top of each existing hook you want guarded:"
        _compose_snippet '<hook>' embedded | while IFS= read -r line; do printf '         %s\n' "$line"; done
        printf '\n'
        printf '%s\n' "  2. Override (NOT recommended unless you understand the consequences):"
        printf '%s\n' "         ai-git-guardrails install --force"
      } >&2
      exit 30
    fi
  fi

  local hook_systems
  hook_systems=$(_detect_hook_systems "$repo")
  if [[ -n "$hook_systems" ]] && (( force == 0 )); then
    warn "detected existing hook system(s) in this repo:"
    while IFS= read -r sys; do printf '       - %s\n' "$sys" >&2; done <<< "$hook_systems"
    warn "ai-git-guardrails will install per-repo hooks alongside, but you may want to compose explicitly."
    warn "for example, in .husky/pre-commit add:"
    _compose_snippet pre-commit embedded | while IFS= read -r line; do info "         $line"; done
  fi

  mkdir -p "$hooks_dir"

  local installed=0 skipped=0 conflicted=0
  for hook in "${AI_GIT_GUARDRAILS_HOOKS[@]}"; do
    # Honor --skip
    local skip=0
    for s in "${skip_hooks[@]:-}"; do [[ "$s" == "$hook" ]] && skip=1; done
    if (( skip == 1 )); then
      skipped=$((skipped + 1))
      continue
    fi

    local target="$hooks_dir/$hook" state
    state=$(_classify_hook "$hooks_dir" "$hook")
    case "$state" in
      ours)
        # Re-install: re-generate to pick up latest version.
        rm -f "$target"
        _generate_shim "$hook" > "$target"
        chmod +x "$target"
        installed=$((installed + 1))
        continue
        ;;
      non-ours)
        if (( force == 0 )); then
          warn "$hook already exists and is not managed by ai-git-guardrails: $target"
          conflicted=$((conflicted + 1))
          continue
        fi
        ;;
    esac
    # Write via rm-then-create to never follow a symlink target.
    rm -f "$target"
    _generate_shim "$hook" > "$target"
    chmod +x "$target"
    installed=$((installed + 1))
  done

  # Set local core.hooksPath so git uses the per-repo hooks we just wrote,
  # including when a global hooksPath (for example wt) would otherwise shadow
  # .git/hooks.
  if (( installed > 0 )); then
    git config --local core.hooksPath "$hooks_dir"
    info "→ set local core.hooksPath = $hooks_dir"
  fi

  green "installed "
  printf '%d/%d hooks in %s\n' "$installed" "${#AI_GIT_GUARDRAILS_HOOKS[@]}" "$repo"
  (( skipped > 0 ))    && yellow "skipped: $skipped\n"
  (( conflicted > 0 )) && yellow "conflicts: $conflicted (use --force to override)\n"
  return 0
}

cmd_uninstall() {
  local repo
  repo=$(_repo_toplevel) || die 10 "not a git repo"
  local hooks_dir
  hooks_dir=$(_repo_hooks_dir) || die 10 "could not resolve hooks dir"

  local removed=0 not_ours=0
  for hook in "${AI_GIT_GUARDRAILS_HOOKS[@]}"; do
    local target="$hooks_dir/$hook" state
    state=$(_classify_hook "$hooks_dir" "$hook")
    case "$state" in
      ours)
        rm -f "$target"
        removed=$((removed + 1))
        ;;
      non-ours)
        not_ours=$((not_ours + 1))
        ;;
    esac
  done

  # If the local core.hooksPath we set during install now points at an empty
  # set of our hooks, restore the global default by unsetting it.
  local local_hp; local_hp=$(_repo_local_hookspath)
  if [[ "$local_hp" == "$hooks_dir" ]]; then
    # Are there any non-ai-git-guardrails hooks left to justify keeping the override?
    local any_other=0
    for hook in "${AI_GIT_GUARDRAILS_HOOKS[@]}"; do
      [[ -f "$hooks_dir/$hook" ]] && any_other=1
    done
    if (( any_other == 0 )); then
      git config --local --unset core.hooksPath
      info "→ unset local core.hooksPath (restored global default)"
    fi
  fi

  green "uninstalled "
  printf '%d ai-git-guardrails hooks from %s\n' "$removed" "$repo"
  (( not_ours > 0 )) && warn "left $not_ours non-ai-git-guardrails hooks intact"
  return 0
}

cmd_run() {
  local hook="${1:-}"
  [[ -n "$hook" ]] || die 10 "usage: ai-git-guardrails run <hook>"
  shift

  # Global bypass.
  [[ "${SKIP_PERSONAL_HOOKS:-0}" == "1" ]] && exit 0

  # User-owned per-repo opt-out.
  local repo
  repo=$(_repo_toplevel || true)
  if [[ -n "$repo" ]] && [[ -f "$AI_GIT_GUARDRAILS_OPT_OUT" ]]; then
    if grep -Fxq "$repo" "$AI_GIT_GUARDRAILS_OPT_OUT"; then
      exit 0
    fi
  fi

  # Defer to lefthook with our shipped config.
  local config="$AI_GIT_GUARDRAILS_TEMPLATES/lefthook.yml"
  [[ -f "$config" ]] || die 40 "ai-git-guardrails lefthook.yml not found at $config"

  # XDG init.sh (PATH extension before sanitization, if user wants it).
  local user_init="$AI_GIT_GUARDRAILS_CONFIG_DIR/init.sh"
  [[ -r "$user_init" ]] && . "$user_init"

  # PATH sanitization (defense against hijack).
  export PATH="${AI_GIT_GUARDRAILS_PATH:-${GUARDRAILS_PATH:-/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:$HOME/.local/share/bun/bin:$HOME/.local/bin}}"

  # Make template path visible to lefthook config.
  export AI_GIT_GUARDRAILS_TEMPLATES="$AI_GIT_GUARDRAILS_TEMPLATES"
  # Backward-compat: older lefthook templates and user hooks may still read GUARDRAILS_TEMPLATES.
  export GUARDRAILS_TEMPLATES="${GUARDRAILS_TEMPLATES:-$AI_GIT_GUARDRAILS_TEMPLATES}"

  case "$hook" in
    commit-msg)
      export LEFTHOOK_COMMIT_MSG_FILE="${1:-}"
      exec env LEFTHOOK_CONFIG="$config" lefthook run commit-msg --no-tty --no-auto-install -- "$@"
      ;;
    pre-push)
      # pre-push receives ref data on stdin. Run branch-guard directly (lefthook
      # consumes pre-push stdin for its templates), then exec lefthook with same.
      local tmp
      tmp=$(mktemp -t ai-git-guardrails-prepush.XXXXXX)
      # Double-quote so $tmp expands at trap-set time. Single quotes would
      # defer expansion until the trap fires — by which point `local tmp`
      # is out of scope and `set -u` aborts.
      trap "rm -f '$tmp'" EXIT
      cat > "$tmp"
      if [[ -z "${SKIP_BRANCH_GUARD:-}" ]] && ! "$AI_GIT_GUARDRAILS_TEMPLATES/checks/branch-guard.sh" < "$tmp"; then
        exit 1
      fi
      env LEFTHOOK_CONFIG="$config" lefthook run pre-push --no-tty --no-auto-install < "$tmp"
      exit $?
      ;;
    *)
      exec env LEFTHOOK_CONFIG="$config" lefthook run "$hook" --no-tty --no-auto-install
      ;;
  esac
}

cmd_doctor() {
  local all=0 root="${HOME}/Documents/GitHub"
  while (($#)); do
    case "$1" in
      --all) all=1; shift ;;
      --root) root="$2"; shift 2 ;;
      -*) die 10 "unknown flag: $1" ;;
      *) die 10 "unexpected positional: $1" ;;
    esac
  done

  if (( all == 1 )); then
    cmd_doctor_all "$root"
    return $?
  fi
  local fail=0
  printf '%-40s' "ai-git-guardrails version"; green "$AI_GIT_GUARDRAILS_VERSION\n"
  printf '%-40s' "templates dir"
  if [[ -f "$AI_GIT_GUARDRAILS_TEMPLATES/lefthook.yml" ]]; then green "$AI_GIT_GUARDRAILS_TEMPLATES\n"
  else red "MISSING: $AI_GIT_GUARDRAILS_TEMPLATES/lefthook.yml\n"; fail=1; fi

  local tool
  for tool in "${AI_GIT_GUARDRAILS_REQUIRED_TOOLS[@]}"; do
    printf '%-40s' "$tool reachable"
    if have "$tool"; then
      green "$(command -v "$tool")\n"
    else
      red "MISSING (required by registry)\n"
      fail=1
    fi
  done
  for tool in "${AI_GIT_GUARDRAILS_OPTIONAL_TOOLS[@]}"; do
    printf '%-40s' "$tool reachable"
    if have "$tool"; then
      green "$(command -v "$tool")\n"
    else
      yellow "NOT FOUND (corresponding registry checks may skip)\n"
    fi
  done

  printf '%-40s' "config dir"
  if [[ -d "$AI_GIT_GUARDRAILS_CONFIG_DIR" ]]; then green "$AI_GIT_GUARDRAILS_CONFIG_DIR\n"
  else dim "(absent — no opt-outs configured)\n"; fi

  # If we're inside a repo, also report install state for THIS repo.
  local repo
  repo=$(_repo_toplevel 2>/dev/null || true)
  if [[ -n "$repo" ]]; then
    local record
    record=$(_audit_repo "$repo")
    _render_repo_audit_detail "$record"
  fi

  return $fail
}

_render_repo_audit_detail() {
  local record="$1"
  local repo opt_out hooks_dir_kind pre_commit pre_push commit_msg category
  IFS=$'\t' read -r repo opt_out hooks_dir_kind pre_commit pre_push commit_msg category <<< "$record"

  printf '\n%s\n' "$(dim "─── current repo: $repo ───")"
  printf '%-40s' "category"; _render_category "$category"
  printf '%-40s' "hooks dir kind"; dim "$hooks_dir_kind\n"
  printf '%-40s' "opt-out"; dim "$opt_out\n"

  _render_hook_detail "pre-commit" "$pre_commit"
  _render_hook_detail "pre-push" "$pre_push"
  _render_hook_detail "commit-msg" "$commit_msg"

  local lh; lh=$(git -C "$repo" config --local --get core.hooksPath 2>/dev/null || true)
  if [[ -n "$lh" ]]; then
    printf '%-40s' "local core.hooksPath"; yellow "$lh\n"
  fi
}

_render_hook_detail() {
  local hook="$1" owner="$2"
  printf '%-40s' "$hook"
  case "$owner" in
    ours) green "installed (ai-git-guardrails)\n" ;;
    non-ours) yellow "present (not ours)\n" ;;
    shadowed) yellow "shadowed by core.hooksPath\n" ;;
    opt-out) dim "opt-out\n" ;;
    *) dim "not installed\n" ;;
  esac
}

_render_category() {
  case "$1" in
    installed) green "installed\n" ;;
    bypass-other) yellow "bypass-other\n" ;;
    opt-out) dim "opt-out\n" ;;
    *) dim "not-installed\n" ;;
  esac
}

cmd_doctor_all() {
  local root="$1"
  [[ -d "$root" ]] || die 10 "scan root does not exist: $root"

  local installed=0 not_installed=0 bypass_other=0 opt_out=0 total=0
  local repos_installed=() repos_not_installed=() repos_bypass_other=() repos_optout=()

  # Walk the root looking for .git/ (or .git file for worktrees).
  while IFS= read -r repo; do
    [[ -z "$repo" ]] && continue
    total=$((total + 1))
    local record audit_repo opt_out_flag hooks_dir_kind pre_commit pre_push commit_msg category
    record=$(_audit_repo "$repo")
    IFS=$'\t' read -r audit_repo opt_out_flag hooks_dir_kind pre_commit pre_push commit_msg category <<< "$record"
    case "$category" in
      installed)
        repos_installed+=("$audit_repo")
        installed=$((installed + 1))
        ;;
      not-installed)
        repos_not_installed+=("$audit_repo")
        not_installed=$((not_installed + 1))
        ;;
      bypass-other)
        repos_bypass_other+=("$audit_repo")
        bypass_other=$((bypass_other + 1))
        ;;
      opt-out)
        repos_optout+=("$audit_repo")
        opt_out=$((opt_out + 1))
        ;;
    esac
  done < <(_find_git_repos "$root")

  printf 'ai-git-guardrails doctor --all — scan root: %s\n' "$root"
  printf '  %d repos | ' "$total"
  green "$installed installed"; printf ' | '
  dim "$not_installed not-installed"; printf ' | '
  yellow "$bypass_other bypass-other"; printf ' | '
  dim "$opt_out opt-out"; printf '\n\n'

  if (( installed > 0 )); then
    green "installed — ai-git-guardrails-managed hooks present:\n"
    for r in "${repos_installed[@]}"; do
      printf '  ✓ %s\n' "${r#$root/}"
    done
    printf '\n'
  fi

  if (( not_installed > 0 )); then
    dim "not-installed — run \`cd <repo> && ai-git-guardrails install\` to enroll:\n"
    for r in "${repos_not_installed[@]}"; do
      printf '  · %s\n' "${r#$root/}"
    done
    printf '\n'
  fi

  if (( bypass_other > 0 )); then
    yellow "bypass-other — core.hooksPath resolves to a non-ai-git-guardrails path:\n"
    for r in "${repos_bypass_other[@]}"; do
      local hp; hp=$(git -C "$r" config --local --get core.hooksPath 2>/dev/null || git -C "$r" config --global --get core.hooksPath 2>/dev/null || true)
      printf '  ✗ %s   (hooksPath: %s)\n' "${r#$root/}" "$hp"
    done
    printf '  fix: in each, add this near the top of the existing hook script:\n'
    _compose_snippet '<hook>' bypass-help | while IFS= read -r line; do dim "    $line\n"; done
    printf '\n'
  fi

  if (( opt_out > 0 )); then
    dim "opt-out — explicitly skipped:\n"
    for r in "${repos_optout[@]}"; do
      printf '  — %s\n' "${r#$root/}"
    done
  fi
}

_find_git_repos() {
  local root="$1"
  # Find dirs that contain .git (either as dir or file for worktrees).
  # Stop descending into a repo once found.
  find "$root" -type d -maxdepth 5 \( -name node_modules -o -name .venv -o -name venv -o -name .worktrees \) -prune -o \
    \( -name .git -o -type f -name .git \) -print 2>/dev/null \
    | xargs -I {} dirname {} | sort -u
}

_audit_repo() {
  local repo="$1"
  local hook owner path local_hp global_hp opt_out hooks_dir_kind category
  local any_ours=0 any_shadowed=0 any_optout=0
  local pre_commit="absent" pre_push="absent" commit_msg="absent"
  opt_out=0
  _repo_is_opted_out "$repo" && opt_out=1

  if ! _classify_repo_hooks "$repo" >/dev/null 2>&1; then
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$repo" "0" "unknown" "absent" "absent" "absent" "not-installed"
    return 0
  fi

  while IFS=$'\t' read -r hook owner path local_hp global_hp _row_opt_out; do
    case "$hook" in
      pre-commit) pre_commit="$owner" ;;
      pre-push) pre_push="$owner" ;;
      commit-msg) commit_msg="$owner" ;;
    esac
    case "$owner" in
      ours) any_ours=1 ;;
      shadowed) any_shadowed=1 ;;
      opt-out) any_optout=1 ;;
    esac
  done < <(_classify_repo_hooks "$repo")

  hooks_dir_kind="default"
  if (( any_shadowed == 1 )); then
    if [[ "$local_hp" != "." ]]; then
      hooks_dir_kind="local-core.hooksPath"
    elif [[ "$global_hp" != "." ]]; then
      hooks_dir_kind="global-core.hooksPath"
    else
      hooks_dir_kind="shadowed"
    fi
  fi

  if (( any_optout == 1 )); then category="opt-out"
  elif (( any_ours == 1 )); then category="installed"
  elif (( any_shadowed == 1 )); then category="bypass-other"
  else category="not-installed"; fi

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$repo" "$opt_out" "$hooks_dir_kind" "$pre_commit" "$pre_push" "$commit_msg" "$category"
}

cmd_global_template() {
  if (($#)); then
    case "$1" in
      generate) shift ;;
      *) die 10 "unknown global-template command: $1" ;;
    esac
  fi
  (($# == 0)) || die 10 "unexpected positional: $1"

  local template_dir="${XDG_DATA_HOME:-$HOME/.local/share}/ai-git-guardrails/git-template"
  local hooks_dir="$template_dir/hooks"
  mkdir -p "$hooks_dir"
  for hook in "${AI_GIT_GUARDRAILS_HOOKS[@]}"; do
    _generate_shim "$hook" > "$hooks_dir/$hook"
    chmod +x "$hooks_dir/$hook"
  done
  git config --global init.templateDir "$template_dir"
  green "global template installed "
  printf '%s\n' "$template_dir"
  info "→ new \`git init\` / \`git clone\` will auto-install ai-git-guardrails hooks"
  info "→ undo: git config --global --unset init.templateDir"
}

cmd_migrate() {
  local apply=0
  while (($#)); do
    case "$1" in
      --apply) apply=1; shift ;;
      *) die 10 "unknown flag: $1" ;;
    esac
  done

  local legacy="$HOME/.git-hooks-personal"
  if [[ ! -d "$legacy" ]]; then
    green "no legacy install found "
    printf 'nothing to migrate\n'
    return 0
  fi

  info "→ legacy install detected at $legacy"
  info ""

  # Find repos enrolled via global core.hooksPath = $legacy
  local global_hp; global_hp=$(_repo_global_hookspath)
  if [[ "$global_hp" == "$legacy" ]]; then
    info "→ global core.hooksPath currently points at $legacy"
    info "  this will be unset (binary install puts ai-git-guardrails on PATH)"
  fi

  # Find opt-out paths to preserve
  local legacy_optout="$legacy/.opt-out"
  if [[ -f "$legacy_optout" ]]; then
    info "→ legacy .opt-out found:"
    sed 's/^/     /' "$legacy_optout"
  fi

  if (( apply == 0 )); then
    info ""
    yellow "DRY RUN — re-run with --apply to perform the migration.\n"
    info "What would happen:"
    info "  1. Unset global core.hooksPath (if it points at $legacy)"
    info "  2. Copy $legacy/.opt-out to $AI_GIT_GUARDRAILS_OPT_OUT (if present)"
    info "  3. Print a list of repos to run \`ai-git-guardrails install\` in"
    info "  4. NOT delete $legacy (you do that manually after verifying)"
    return 0
  fi

  # Apply.
  if [[ "$global_hp" == "$legacy" ]]; then
    git config --global --unset core.hooksPath
    green "✓ unset global core.hooksPath\n"
  fi

  if [[ -f "$legacy_optout" ]]; then
    mkdir -p "$AI_GIT_GUARDRAILS_CONFIG_DIR"
    cp "$legacy_optout" "$AI_GIT_GUARDRAILS_OPT_OUT"
    green "✓ migrated opt-out file to $AI_GIT_GUARDRAILS_OPT_OUT\n"
  fi

  info ""
  yellow "next: install ai-git-guardrails per-repo in any repo you want covered.\n"
  info "for each repo:"
  info "  cd <repo> && ai-git-guardrails install"
  info ""
  info "when you've verified the new install works:"
  info "  rm -rf $legacy"
}

# ---------- dispatch ----------
main() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    install)        cmd_install "$@" ;;
    uninstall)      cmd_uninstall "$@" ;;
    run)            cmd_run "$@" ;;
    doctor)         cmd_doctor "$@" ;;
    migrate)        cmd_migrate "$@" ;;
    --global-template|global-template) cmd_global_template "$@" ;;
    --version|-V)   cmd_version ;;
    -h|--help|help|"") cmd_help ;;
    *)              die 10 "unknown subcommand: $sub (try 'ai-git-guardrails --help')" ;;
  esac
}

cmd_help() {
  cat <<EOF
ai-git-guardrails $AI_GIT_GUARDRAILS_VERSION — personal git-hook quality layer

usage:
  ai-git-guardrails install [--force] [--skip <hook>]
                                     install hooks into the current repo (per-repo,
                                     ownership-marker based, conflict-aware)
  ai-git-guardrails uninstall               remove only ai-git-guardrails-managed hooks
EOF
  printf '  ai-git-guardrails %s <hook>              execute the named hook (invoked by installed shims)\n' run
  cat <<EOF
  ai-git-guardrails doctor                  audit current repo + tool reachability
  ai-git-guardrails migrate [--apply]       migrate from legacy global-hooksPath install
  ai-git-guardrails --global-template       configure git init.templateDir for auto-install on new clones

  ai-git-guardrails --version | -V
  ai-git-guardrails --help

config:
  ${XDG_CONFIG_HOME:-$HOME/.config}/ai-git-guardrails/         user config dir (opt-out, init.sh)
  $AI_GIT_GUARDRAILS_TEMPLATES/checks/registry.sh   source of truth for what runs

bypass:
  SKIP_PERSONAL_HOOKS=1                skip all ai-git-guardrails checks
  per-check SKIP_* env vars          skip one registry check
  ALLOW_PROTECTED_PUSH=1               one-time protected-branch override
  git commit --no-verify               nuclear (skips ai-git-guardrails + repo hooks)
EOF
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
